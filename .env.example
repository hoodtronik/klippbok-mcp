# Copy to `.env` and fill the keys for the VLM providers you use.
# The MCP server reads these from its environment and passes them through
# to Klippbok subprocesses (caption + audit + ingest --caption) via env.
# `.env` is gitignored.

# Required for `klippbok_caption` with provider=gemini.
# Free tier available at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required for `klippbok_caption` with provider=replicate.
REPLICATE_API_TOKEN=

# Path to the Python interpreter that has Klippbok installed.
# Defaults to sys.executable if unset — which works if Klippbok is
# installed in the same venv as the MCP server. Most users will want to
# point this at a separate venv where `pip install klippbok[all]` was run
# (e.g. from the Klippbok Pinokio launcher, a standalone clone, etc.).
KLIPPBOK_PYTHON=
